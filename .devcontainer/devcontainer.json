{
  "name": "Node.js Library",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:24",
  // 4 GB RAM for the container
  "runArgs": ["--memory=4g", "--memory-swap=4g", "--cpus=2"],
  "hostRequirements": {
    "memory": "4gb"
  },
  // pnpm via corepack (ships with Node 24) + install deps
  "postCreateCommand": "corepack use pnpm@11.0.8 && pnpm install --frozen-lockfile",
  // Forward vitest --ui port, also Ollama
  "forwardPorts": [51204, 11434],
  "portsAttributes": {
    "51204": {
      "label": "Vitest UI",
      "onAutoForward": "notify"
    },
    "11434": {
      "label": "Ollama",
      "onAutoForward": "notify"
    }
  },
  "remoteEnv": {
    "NODE_ENV": "development",
    // Give Node.js ~3 GB for heap
    "NODE_OPTIONS": "--max-old-space-size=3072",
    // pnpm store inside the container (no cross-device issues)
    "PNPM_HOME": "/home/node/.local/share/pnpm"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "coverage-gutters.coverageFileNames": [".coverage/lcov.info"],
        "vitest.enable": true,
        "vitest.commandLine": "pnpm run test:only"
      },
      "extensions": [
        // TypeScript / JavaScript
        "ms-vscode.vscode-typescript-next",
        "ms-vscode.js-debug",
        // Lint & format
        "oxc.oxc-vscode",
        // Testing
        "vitest.explorer",
        // Coverage
        "ryanluker.vscode-coverage-gutters",
        // Git
        "adam-bender.commit-message-editor",
        // GitHub
        "github.vscode-github-actions",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  }
}
