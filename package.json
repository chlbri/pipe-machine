{
  "name": "@bemedev/pipe-machine",
  "version": "1.0.1",
  "description": "A strongly-typed pipe class library for function composition with advanced TypeScript support",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/pipe-machine"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "pipe",
    "function-composition",
    "strongly-typed",
    "typescript",
    "functional-programming",
    "utilities",
    "lazy-implementation"
  ],
  "files": [
    "lib",
    "public"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "_preconfig": "chmod +x .husky/commit-msg",
    "build": "pnpm run rm:lib && pnpm run rolldown",
    "ci": "CI_START=$(date +%s) && pnpm run config && pnpm run lint && pnpm run test && pnpm run p-q && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:off": "CI_START=$(date +%s) && pnpm run config:off && pnpm run lint && pnpm run test && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:admin": "pnpm run rm && pnpm run upgrade:fast && pnpm run ci",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "_lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run lint",
    "build:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run build",
    "p-q": "pretty-quick",
    "posttest": "build-tests post && pnpm run fmt",
    "prepare": "husky",
    "prepublishOnly": "",
    "pretest": "pnpm run build && build-tests pre && pnpm run size",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rm": "pnpx rimraf ./node_modules ./pnpm-lock.yaml",
    "rm:lib": "pnpx rimraf ./lib",
    "rolldown": "rolldown -c",
    "test:coverage": "vitest run",
    "test": "pnpm run test:coverage",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "upgrade": "pnpm dlx @bemedev/upgrade-npm-package",
    "size": "size-limit",
    "upgrade:fast": "pnpm up --latest"
  },
  "size-limit": [
    {
      "path": "lib/*.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/*.cjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@bemedev/dev-utils": "^0.6.11",
    "@bemedev/typings": "^0.5.5",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^25.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "4.1.6",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "pretty-quick": "^4.2.2",
    "rolldown": "1.0.0",
    "size-limit": "^12.1.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "valibot": "^1.4.0",
    "vitest": "^4.1.6",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@bemedev/boolean-recursive": "^0.0.3",
    "@bemedev/decompose": "^2.2.0",
    "@bemedev/pipe": "1.6.0",
    "@standard-schema/spec": "^1.1.0"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
